{%- style -%}
  .section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .section-{{ section.id }} .ak-logo-heading-wrapper {
    margin-bottom: 3rem;
  }

  .section-{{ section.id }} .ak-logo-heading {
    color: {{ section.settings.heading_color }};
    text-align: center;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 1.1rem;
    font-weight: 500;
    margin: 0;
  }

  /* Full Width Marquee Setup */
  .section-{{ section.id }} .ak-logo-marquee {
    display: flex;
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .section-{{ section.id }} .ak-logo-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: ak-marquee-scroll {{ section.settings.scroll_speed }}s linear infinite;
  }

  .section-{{ section.id }} .ak-logo-marquee.pause-on-hover:hover .ak-logo-track {
    animation-play-state: paused;
  }

  .section-{{ section.id }} .ak-logo-item {
    position: relative;
    flex: 0 0 auto;
    width: {{ section.settings.logo_width }}px;
    margin: 0 {{ section.settings.logo_gap }}px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Diamond Separator (Matches Screenshot) */
  {% if section.settings.show_separators %}
    .section-{{ section.id }} .ak-logo-item::after {
      content: '◆';
      position: absolute;
      right: -{{ section.settings.logo_gap }}px;
      color: {{ section.settings.separator_color }};
      font-size: 8px;
      top: 50%;
      transform: translateY(-50%) translateX(50%);
    }
    /* Hide separator on the very last item of a track to prevent double diamonds */
    .section-{{ section.id }} .ak-logo-item:last-child::after {
      display: none;
    }
  {% endif %}

  /* Static and Hover Image Effects */
  .section-{{ section.id }} .ak-logo-item img,
  .section-{{ section.id }} .ak-logo-item svg {
    max-width: 100%;
    height: auto;
    transition: all 0.4s ease-in-out;
    {% if section.settings.static_style == 'grayscale' %}
      filter: grayscale(100%) opacity({{ section.settings.static_opacity }}%);
    {% else %}
      filter: grayscale(0%) opacity(100%);
    {% endif %}
  }

  .section-{{ section.id }} .ak-logo-item:hover img,
  .section-{{ section.id }} .ak-logo-item:hover svg {
    {% if section.settings.hover_style == 'color' %}
      filter: grayscale(0%) opacity(100%);
    {% elsif section.settings.hover_style == 'grayscale' %}
      filter: grayscale(100%) opacity({{ section.settings.static_opacity }}%);
    {% endif %}
  }

  @keyframes ak-marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Navigation & Pagination Styling */
  .section-{{ section.id }} .ak-logo-navigation {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .section-{{ section.id }} .ak-logo-arrow {
    background: {{ section.settings.arrow_bg_color }};
    color: {{ section.settings.arrow_color }};
    border: 1px solid {{ section.settings.arrow_border_color }};
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .section-{{ section.id }} .ak-logo-arrow:hover {
    background: {{ section.settings.arrow_color }};
    color: {{ section.settings.arrow_bg_color }};
  }

  .section-{{ section.id }} .ak-logo-dots {
    display: flex;
    gap: 8px;
  }

  .section-{{ section.id }} .ak-logo-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: {{ section.settings.dot_color }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .section-{{ section.id }} .ak-logo-dot:hover,
  .section-{{ section.id }} .ak-logo-dot.is-active {
    background: {{ section.settings.active_dot_color }};
  }
{%- endstyle -%}

<div class="section-{{ section.id }} ak-logo-slider">
  
  {%- if section.settings.heading != blank -%}
    <div class="page-width ak-logo-heading-wrapper">
      <h2 class="ak-logo-heading">
        {{ section.settings.heading }}
      </h2>
    </div>
  {%- endif -%}

  <!-- Full Width Track Container -->
  <div class="ak-logo-marquee{% if section.settings.pause_on_hover %} pause-on-hover{% endif %}">
    <div class="ak-logo-track">
      
      <!-- First Loop -->
      {%- for block in section.blocks -%}
        <div class="ak-logo-item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
          
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | image_tag: alt: block.settings.alt_text, loading: 'lazy' }}
          {%- else -%}
            <div class="ak-logo-placeholder">
              {{ 'logo' | placeholder_svg_tag }}
            </div>
          {%- endif -%}

          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}

      <!-- Duplicated Loop for Seamless Infinite Scroll -->
      {%- for block in section.blocks -%}
        <div class="ak-logo-item" aria-hidden="true">
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" tabindex="-1">{%- endif -%}
          
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | image_tag: alt: block.settings.alt_text, loading: 'lazy' }}
          {%- else -%}
            <div class="ak-logo-placeholder">
              {{ 'logo' | placeholder_svg_tag }}
            </div>
          {%- endif -%}

          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

  <!-- Optional Navigation & Pagination -->
  {%- if section.settings.show_arrows or section.settings.show_dots -%}
    <div class="ak-logo-navigation">
      {%- if section.settings.show_arrows -%}
        <button class="ak-logo-arrow" type="button" aria-label="Previous">←</button>
      {%- endif -%}

      {%- if section.settings.show_dots -%}
        <div class="ak-logo-dots">
          {%- for block in section.blocks -%}
            <span class="ak-logo-dot{% if forloop.first %} is-active{% endif %}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_arrows -%}
        <button class="ak-logo-arrow" type="button" aria-label="Next">→</button>
      {%- endif -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "AK Logo Carousel",
  "tag": "section",
  "class": "section",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted By"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F3EFE9"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#5E7783"
    },
    {
      "type": "header",
      "content": "Logo Styling"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Max Logo Width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_gap",
      "label": "Gap Between Logos",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "select",
      "id": "static_style",
      "label": "Static Logo State",
      "options": [
        { "value": "grayscale", "label": "Grayscale & Faded" },
        { "value": "color", "label": "Full Color" }
      ],
      "default": "grayscale"
    },
    {
      "type": "range",
      "id": "static_opacity",
      "label": "Static Logo Opacity",
      "min": 10,
      "max": 100,
      "step": 10,
      "unit": "%",
      "default": 60
    },
    {
      "type": "select",
      "id": "hover_style",
      "label": "Hover Logo State",
      "options": [
        { "value": "color", "label": "Full Color" },
        { "value": "grayscale", "label": "Grayscale" },
        { "value": "none", "label": "No Change" }
      ],
      "default": "color"
    },
    {
      "type": "header",
      "content": "Separators"
    },
    {
      "type": "checkbox",
      "id": "show_separators",
      "label": "Show Diamond Separators",
      "default": true
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator Color",
      "default": "#C1C1C1"
    },
    {
      "type": "header",
      "content": "Carousel Settings"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll Speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "s",
      "default": 25
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Navigation (Optional)"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": false
    },
    {
      "type": "color",
      "id": "arrow_color",
      "label": "Arrow Icon Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Arrow Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "arrow_border_color",
      "label": "Arrow Border Color",
      "default": "#dddddd"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Dot Pagination",
      "default": false
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot Color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "active_dot_color",
      "label": "Active Dot Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Logo Link"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "default": "Brand Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "AK Logo Carousel",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}