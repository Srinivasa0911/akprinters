      "default": "#3b82f6"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Statistic Heading Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Detailed Description Color",
      "default": "#64748b"
    },
    {
      "type": "header",
      "content": "Counter Typography Sizing"
