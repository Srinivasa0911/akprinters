{%- style -%}
  .advanced-footer-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    border-top: 1px solid {{ section.settings.border_color }};
  }

  @media screen and (min-width: 750px) {
    .advanced-footer-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  .adv-footer__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Grid Layout */
  .adv-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 750px) {
    .adv-footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .adv-footer__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 4rem;
    }
  }

  .adv-footer__block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Typography Styles from Settings */
  .adv-footer__heading {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .adv-footer__text {
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
  }

  /* Link Styles */
  .adv-footer__link {
    color: {{ section.settings.link_color }};
    font-size: {{ section.settings.link_size }}px;
    text-decoration: none;
    transition: opacity 0.3s ease;
    line-height: 1.6;
  }
  
  .adv-footer__link:hover {
    opacity: 0.7;
    text-decoration: underline;
  }

  /* Menu Block Styles */
  .adv-footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* Logo & Social Styles */
  .adv-footer__logo-link {
    display: inline-block;
    margin-bottom: 1.5rem;
  }
  .adv-footer__logo-img {
    display: block;
    max-width: 100%;
    height: auto;
  }
  .adv-footer__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
    align-items: center;
  }
  .adv-footer__social-link {
    display: block;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .adv-footer__social-link:hover {
    opacity: 0.7;
    transform: translateY(-2px);
  }
  .adv-footer__social-img {
    display: block;
    object-fit: contain;
  }

  /* Contact Styles */
  .adv-footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  
  .adv-footer__contact-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    fill: {{ section.settings.icon_color }};
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Bottom Copyright, Legal & Payment Bar */
  .adv-footer__bottom {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid {{ section.settings.border_color }};
  }
  
  .adv-footer__bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
  }
  
  @media screen and (min-width: 750px) {
    .adv-footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .adv-footer__legal-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .adv-footer__legal-group {
      align-items: flex-start;
    }
  }

  .adv-footer__legal-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  /* Payment Image */
  .adv-footer__payment {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .adv-footer__payment-img {
    display: block;
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }
{%- endstyle -%}

<footer class="advanced-footer-{{ section.id }}">
  <div class="adv-footer__container">
    
    <div class="adv-footer__grid">
      {%- for block in section.blocks -%}
        <div class="adv-footer__block" {{ block.shopify_attributes }}>
          
          {%- case block.type -%}
            
            {%- when 'logo' -%}
              {%- if block.settings.logo != blank -%}
                <a href="{{ routes.root_url }}" class="adv-footer__logo-link" style="width: {{ block.settings.logo_width }}px;">
                  {{ block.settings.logo | image_url: width: block.settings.logo_width | image_tag: class: 'adv-footer__logo-img', loading: 'lazy', alt: shop.name }}
                </a>
              {%- else -%}
                <h2 class="adv-footer__heading">{{ shop.name }}</h2>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <div class="adv-footer__text" style="opacity: 0.8;">{{ block.settings.description }}</div>
              {%- endif -%}

              <div class="adv-footer__socials">
                {%- for i in (1..6) -%}
                  {%- assign icon_key = 'social_icon_' | append: i -%}
                  {%- assign link_key = 'social_link_' | append: i -%}
                  {%- assign icon = block.settings[icon_key] -%}
                  {%- assign link = block.settings[link_key] -%}
                  
                  {%- if icon != blank and link != blank -%}
                    {%- assign icon_style = 'width: ' | append: block.settings.social_icon_width | append: 'px;' -%}
                    <a href="{{ link }}" class="adv-footer__social-link" target="_blank" rel="noopener noreferrer">
                      {{ icon | image_url: width: block.settings.social_icon_width | image_tag: class: 'adv-footer__social-img', style: icon_style, loading: 'lazy', alt: 'Social Icon' }}
                    </a>
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- when 'link_list' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="adv-footer__heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="adv-footer__menu">
                  {%- for link in block.settings.menu.links -%}
                    <li><a href="{{ link.url }}" class="adv-footer__link">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'location' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="adv-footer__heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              <div class="adv-footer__contact-item">
                {%- if block.settings.show_icon -%}
                  <svg class="adv-footer__contact-icon" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                {%- endif -%}
                <div class="adv-footer__text">{{ block.settings.address }}</div>
              </div>

            {%- when 'phone' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="adv-footer__heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              <div class="adv-footer__contact-item">
                {%- if block.settings.show_icon -%}
                  <svg class="adv-footer__contact-icon" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                {%- endif -%}
                <a href="tel:{{ block.settings.phone_number | replace: ' ', '' }}" class="adv-footer__link">
                  {{ block.settings.phone_number | escape }}
                </a>
              </div>

            {%- when 'email' -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="adv-footer__heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              <div class="adv-footer__contact-item">
                {%- if block.settings.show_icon -%}
                  <svg class="adv-footer__contact-icon" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                {%- endif -%}
                <a href="mailto:{{ block.settings.email_address }}" class="adv-footer__link">
                  {{ block.settings.email_address | escape }}
                </a>
              </div>

          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <!-- Bottom Copyright, Legal & Payment -->
    <div class="adv-footer__bottom">
      <div class="adv-footer__bottom-inner">
        
        <!-- Left Side: Copyright & Legal -->
        <div class="adv-footer__legal-group">
          <div class="adv-footer__text" style="opacity: 0.8;">
            &copy; {{ 'now' | date: "%Y" }} {{ shop.name | link_to: routes.root_url }}. All Rights Reserved.
          </div>
          
          {%- if section.settings.privacy_link != blank or section.settings.terms_link != blank -%}
            <div class="adv-footer__legal-links">
              {%- if section.settings.privacy_link != blank -%}
                <a href="{{ section.settings.privacy_link }}" class="adv-footer__link" style="opacity: 0.8;">{{ section.settings.privacy_text | default: "Privacy Policy" }}</a>
              {%- endif -%}
              
              {%- if section.settings.terms_link != blank -%}
                <a href="{{ section.settings.terms_link }}" class="adv-footer__link" style="opacity: 0.8;">{{ section.settings.terms_text | default: "Terms & Conditions" }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <!-- Right Side: Single Uploaded Payment Image -->
        {%- if section.settings.show_payment_icons -%}
          <div class="adv-footer__payment-container">
            <span class="visually-hidden">Supported payment methods</span>
            <div class="adv-footer__payment">
              {%- if section.settings.payment_image != blank -%}
                {%- assign payment_style = 'width: ' | append: section.settings.payment_image_width | append: 'px;' -%}
                {%- assign payment_alt = section.settings.payment_image.alt | default: 'Payment Methods' -%}
                {{ section.settings.payment_image | image_url: width: section.settings.payment_image_width | image_tag: class: 'adv-footer__payment-img', style: payment_style, loading: 'lazy', alt: payment_alt }}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
        
      </div>
    </div>
    
  </div>
</footer>

{% schema %}
{
  "name": "Advanced Footer",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#9ca3af"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Main Layout Icon Color",
      "default": "#60a5fa"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Line Color",
      "default": "#1f2937"
    },
    {
      "type": "header",
      "content": "Typography Sizes"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12, "max": 24, "step": 1,
      "default": 16, "unit": "px",
      "label": "Heading Font Size"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12, "max": 20, "step": 1,
      "default": 14, "unit": "px",
      "label": "Text Font Size"
    },
    {
      "type": "range",
      "id": "link_size",
      "min": 12, "max": 20, "step": 1,
      "default": 14, "unit": "px",
      "label": "Link Font Size"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16, "max": 40, "step": 2,
      "default": 20, "unit": "px",
      "label": "Contact Icon Size"
    },
    {
      "type": "header",
      "content": "Custom Payment Image"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment image",
      "default": true
    },
    {
      "type": "range",
      "id": "payment_image_width",
      "min": 50, "max": 400, "step": 10,
      "default": 250, "unit": "px",
      "label": "Payment Image Width"
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Payment Methods Image",
      "info": "Upload a single banner image containing all your payment icons (e.g., Visa, Mastercard, PayPal)."
    },
    {
      "type": "header",
      "content": "Legal Links (Bottom Bar)"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy Policy Text",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy Policy Link"
    },
    {
      "type": "text",
      "id": "terms_text",
      "label": "Terms & Conditions Text",
      "default": "Terms & Conditions"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms & Conditions Link"
    },
    {
      "type": "header",
      "content": "Layout Spacing"
    },
    {
      "type": "number",
      "id": "container_width",
      "label": "Maximum Width (px)",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0, "max": 100, "step": 4,
      "default": 64, "unit": "px",
      "label": "Desktop Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0, "max": 100, "step": 4,
      "default": 64, "unit": "px",
      "label": "Desktop Bottom Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0, "max": 100, "step": 4,
      "default": 40, "unit": "px",
      "label": "Mobile Top Padding"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0, "max": 100, "step": 4,
      "default": 40, "unit": "px",
      "label": "Mobile Bottom Padding"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Store Logo & Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Footer Logo"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 50, "max": 250, "step": 10,
          "default": 120, "unit": "px",
          "label": "Logo Width"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Store Description",
          "default": "<p>Providing the best products for our customers worldwide.</p>"
        },
        {
          "type": "header",
          "content": "Social Media Icons"
        },
        {
          "type": "range",
          "id": "social_icon_width",
          "min": 16, "max": 48, "step": 2,
          "default": 24, "unit": "px",
          "label": "Social Icon Size"
        },
        { "type": "image_picker", "id": "social_icon_1", "label": "Icon 1 Image" },
        { "type": "url", "id": "social_link_1", "label": "Icon 1 Link" },
        { "type": "image_picker", "id": "social_icon_2", "label": "Icon 2 Image" },
        { "type": "url", "id": "social_link_2", "label": "Icon 2 Link" },
        { "type": "image_picker", "id": "social_icon_3", "label": "Icon 3 Image" },
        { "type": "url", "id": "social_link_3", "label": "Icon 3 Link" },
        { "type": "image_picker", "id": "social_icon_4", "label": "Icon 4 Image" },
        { "type": "url", "id": "social_link_4", "label": "Icon 4 Link" },
        { "type": "image_picker", "id": "social_icon_5", "label": "Icon 5 Image" },
        { "type": "url", "id": "social_link_5", "label": "Icon 5 Link" },
        { "type": "image_picker", "id": "social_icon_6", "label": "Icon 6 Image" },
        { "type": "url", "id": "social_link_6", "label": "Icon 6 Link" }
      ]
    },
    {
      "type": "link_list",
      "name": "Quick Links Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        }
      ]
    },
    {
      "type": "location",
      "name": "Location Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Our Location"
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show Location Icon",
          "default": true
        },
        {
          "type": "richtext",
          "id": "address",
          "label": "Address Details",
          "default": "<p>123 Commerce Blvd<br>Suite 100<br>New York, NY 10001</p>"
        }
      ]
    },
    {
      "type": "phone",
      "name": "Phone Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Call Us"
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show Phone Icon",
          "default": true
        },
        {
          "type": "text",
          "id": "phone_number",
          "label": "Phone Number",
          "default": "+1 (555) 123-4567"
        }
      ]
    },
    {
      "type": "email",
      "name": "Email Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Email Us"
        },
        {
          "type": "checkbox",
          "id": "show_icon",
          "label": "Show Email Icon",
          "default": true
        },
        {
          "type": "text",
          "id": "email_address",
          "label": "Email Address",
          "default": "support@yourstore.com"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advanced Footer",
      "blocks": [
        { "type": "logo" },
        { "type": "link_list" },
        { "type": "location" },
        { "type": "email" }
      ]
    }
  ]
}
{% endschema %}