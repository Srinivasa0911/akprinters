{%- style -%}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .ak-contact-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .ak-contact-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .ak-contact-header h2 {
    color: {{ section.settings.heading_color }} !important;
    font-size: {{ section.settings.heading_size_mobile }}px !important;
    margin-top: 0;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .ak-contact-header p.ak-contact-desc {
    color: {{ section.settings.description_color }} !important;
    font-size: {{ section.settings.description_size_mobile }}px !important;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
  }

  .ak-contact-grid {
    display: grid;
    grid-template-columns: 1fr; 
    gap: 2rem;
  }

  /* Contact Card Styling */
  .ak-contact-card-wrapper {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
    height: 100%;
  }

  .ak-contact-card-wrapper:hover {
    transform: translateY(-5px);
  }

  .ak-contact-item {
    background-color: {{ section.settings.card_bg_color }};
    border: {{ section.settings.card_border_thickness }}px solid {{ section.settings.card_border_color }};
    padding: 3rem 2rem;
    border-radius: {{ section.settings.card_border_radius }}px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    transition: border-color 0.3s ease;
  }

  .ak-contact-icon {
    width: 40px;
    height: 40px;
    fill: {{ section.settings.icon_color }};
    margin-bottom: 1.5rem;
    transition: fill 0.3s ease;
  }

  .ak-contact-item h4 {
    margin: 0 0 1rem 0;
    color: {{ section.settings.card_title_color }} !important;
    font-size: {{ section.settings.card_title_size_mobile }}px !important;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .ak-contact-item p, 
  .ak-contact-item span {
    margin: 0;
    color: {{ section.settings.card_text_color }} !important;
    font-size: {{ section.settings.card_text_size_mobile }}px !important;
    line-height: 1.6;
    display: inline-block;
    transition: color 0.3s ease;
  }

  /* Inline Anchor Link Styles inside the card */
  .ak-contact-item a {
    color: {{ section.settings.card_link_color }} !important;
    font-size: {{ section.settings.card_text_size_mobile }}px !important;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  /* Hover States for the entire linked card */
  a.ak-contact-card-wrapper:hover .ak-contact-item h4,
  a.ak-contact-card-wrapper:hover .ak-contact-item span,
  a.ak-contact-card-wrapper:hover .ak-contact-item p,
  .ak-contact-item a:hover {
    color: {{ section.settings.card_link_hover_color }} !important;
  }

  a.ak-contact-card-wrapper:hover .ak-contact-icon {
    fill: {{ section.settings.card_link_hover_color }};
  }
  
  a.ak-contact-card-wrapper:hover .ak-contact-item {
    border-color: {{ section.settings.card_link_hover_color }};
  }

  /* Desktop Layout & Font Adjustments */
  @media screen and (min-width: 750px) {
    .ak-contact-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
    
    .ak-contact-header h2 {
      font-size: {{ section.settings.heading_size_desktop }}px !important;
    }
    .ak-contact-header p.ak-contact-desc {
      font-size: {{ section.settings.description_size_desktop }}px !important;
    }
    
    .ak-contact-item h4 {
      font-size: {{ section.settings.card_title_size_desktop }}px !important;
    }
    .ak-contact-item p, 
    .ak-contact-item a,
    .ak-contact-item span {
      font-size: {{ section.settings.card_text_size_desktop }}px !important;
    }
  }
{%- endstyle -%}

<!-- Added Section Anchor ID -->
<div class="section-{{ section.id }} ak-contact-section" {% if section.settings.section_anchor != blank %}id="{{ section.settings.section_anchor | handleize }}"{% endif %}>
  <div class="ak-contact-container">
    
    <div class="ak-contact-header">
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.description != blank -%}
        <p class="ak-contact-desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="ak-contact-grid">
      {%- for block in section.blocks -%}
        
        <!-- Added Block Anchor ID and Updated Link Type -->
        {%- if block.settings.url != blank -%}
          <a href="{{ block.settings.url }}" class="ak-contact-card-wrapper" {% if block.settings.anchor_id != blank %}id="{{ block.settings.anchor_id | handleize }}"{% endif %} {{ block.shopify_attributes }}>
        {%- else -%}
          <div class="ak-contact-card-wrapper" {% if block.settings.anchor_id != blank %}id="{{ block.settings.anchor_id | handleize }}"{% endif %} {{ block.shopify_attributes }}>
        {%- endif -%}

        <div class="ak-contact-item">
          <svg class="ak-contact-icon" viewBox="0 0 24 24">
            {%- if block.type == 'address' -%}
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-1.12 2.5-2.5-1.12 2.5-2.5 2.5z"/>
            {%- elsif block.type == 'phone' -%}
              <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
            {%- elsif block.type == 'email' -%}
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            {%- endif -%}
          </svg>

          <h4>{{ block.settings.title }}</h4>
          {%- if block.type == 'email' -%}
            <span>{{ block.settings.text }}</span>
          {%- elsif block.type == 'phone' -%}
            <span>{{ block.settings.text }}</span>
          {%- else -%}
            <p>{{ block.settings.text | newline_to_br }}</p>
          {%- endif -%}
        </div>

        {%- if block.settings.url != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}

      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
